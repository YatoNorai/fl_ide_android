{
  "schema_version": 1,
  "sdk": "flutter",
  "sdk_version": "2026-03-17",
  "display_name": "Flutter SDK (zhzhzhy)",
  "description": "Daily Flutter SDK build for Termux ARM64. Includes Dart SDK and Flutter tools. Updated regularly from official Flutter releases.",
  "package": {
    "type": "zip",
    "url": "https://github.com/zhzhzhy/Flutter-SDK-ARM64/releases/download/Flutter-SDK-2026-03-17/Flutter-SDK-ARM64.zip",
    "filename": "Flutter-SDK-ARM64.zip",
    "arch": "arm64",
    "size_mb": 600
  },
  "package_author": {
    "name": "zhzhzhy",
    "github": "https://github.com/zhzhzhy/Flutter-SDK-ARM64"
  },
  "json_author": {
    "name": "Yato",
    "date": "2026-03-18"
  },
  "install_steps": [
    {
      "type": "shell",
      "command": "mkdir -p $PREFIX/tmp",
      "description": "Preparing directories"
    },
    {
      "type": "extract",
      "dest": "$PREFIX",
      "description": "Extracting Flutter SDK to $PREFIX"
    },
    {
      "type": "shell",
      "command": "chmod -R 755 $PREFIX/flutter/bin $PREFIX/flutter/bin/cache/dart-sdk/bin 2>/dev/null || true",
      "description": "Fixing permissions on Flutter binaries"
    },
    {
      "type": "shell",
      "command": "grep -qxF 'export PATH=\"$PATH:$PREFIX/flutter/bin\"' $HOME/.bashrc || echo 'export PATH=\"$PATH:$PREFIX/flutter/bin\"' >> $HOME/.bashrc",
      "description": "Adding Flutter to PATH"
    }
  ],
  "config_steps": [
    {
      "type": "shell",
      "command": "flutter config --no-analytics 2>&1 || true",
      "description": "Disabling analytics"
    },
    {
      "type": "shell",
      "command": "flutter config --android-sdk \"$ANDROID_HOME\" 2>&1 || true",
      "description": "Configuring Android SDK path"
    },
    {
      "type": "shell",
      "command": "flutter --version 2>&1",
      "description": "Verifying Flutter installation"
    }
  ],
  "verify_binary": "flutter",
  "verify_command": "flutter --version",
  "run_config": {
    "run": "flutter run",
    "supports_devices": true,
    "device_param": "-d",
    "build_apk": "flutter build apk",
    "build_appbundle": "flutter build appbundle",
    "build_debug": "flutter build apk --debug"
  },
  "sdk_config": {
    "new_project_cmd": "flutter create $name",
    "default_entry_file": "lib/main.dart",
    "file_extensions": ["dart", "yaml", "json"],
    "sync_command": "flutter pub get",
    "sync_trigger_file": "pubspec.yaml",
    "format_command": "dart format"
  },
  "dap_config": {
    "adapter_binary": "$FLUTTER_ROOT/bin/flutter",
    "adapter_args": ["debug_adapter"],
    "adapter_id": "dart",
    "launch_program": "lib/main.dart",
    "devices_command": "$FLUTTER_ROOT/bin/flutter devices --machine",
    "build_done_strings": [
      "Syncing files to device",
      "flutter run key commands",
      "Running with soundNullSafety",
      "To hot reload"
    ],
    "platform_device_map": {
      "android": "android",
      "web": "web-server",
      "linux": "linux"
    },
    "web_platform": "web",
    "web_server_args": [
      "-d", "web-server",
      "--web-port", "5050",
      "--web-hostname", "localhost",
      "--no-start-paused"
    ]
  }
}
