{
  "schema_version": 1,
  "sdk": "reactNative",
  "sdk_version": "latest",
  "display_name": "React Native (Expo)",
  "description": "React Native development via Expo on Termux. Supports ARM64. Uses Node.js LTS and Expo CLI. Create and run React Native apps on Android via Expo Go or a direct build.",
  "package": {
    "type": "pkg",
    "arch": "arm64",
    "size_mb": 80
  },
  "package_author": {
    "name": "Termux / Node.js Foundation",
    "github": "https://github.com/termux/termux-packages"
  },
  "json_author": {
    "name": "Yato",
    "date": "2026-04-08"
  },
  "install_steps": [
    {
      "type": "shell",
      "command": "apt-get update -y 2>&1 && apt-get install -y nodejs-lts 2>&1",
      "description": "Installing Node.js LTS"
    }
  ],
  "config_steps": [
    {
      "type": "shell",
      "command": "node --version 2>&1 && npm --version 2>&1",
      "description": "Verifying Node.js and npm versions"
    },
    {
      "type": "shell",
      "command": "npm install -g typescript typescript-language-server 2>&1",
      "description": "Installing TypeScript Language Server (LSP)"
    },
    {
      "type": "shell",
      "command": "typescript-language-server --version 2>&1 && echo 'LSP OK'",
      "description": "Verifying TypeScript LSP binary"
    }
  ],
  "cleanup_steps": [
    {
      "type": "shell",
      "command": "npm uninstall -g typescript typescript-language-server 2>&1 || true",
      "description": "Removing globally installed npm packages on error"
    }
  ],
  "uninstall_steps": [
    {
      "type": "shell",
      "command": "npm uninstall -g typescript typescript-language-server 2>&1 || true",
      "description": "Removing TypeScript LSP"
    },
    {
      "type": "shell",
      "command": "apt-get remove -y nodejs-lts 2>&1 || true",
      "description": "Removing Node.js LTS"
    }
  ],
  "verify_binary": "node",
  "verify_command": "node --version",
  "run_config": {
    "run": "npx expo start",
    "supports_devices": true,
    "device_param": "--android",
    "build_debug": "npx expo export",
    "build_release": "npx expo export --platform android"
  },
  "sdk_config": {
    "new_project_cmd": "npx --yes create-expo-app $name",
    "default_entry_file": "App.tsx",
    "file_extensions": ["js", "jsx", "ts", "tsx", "json"],
    "sync_command": "npm install",
    "sync_trigger_file": "package.json",
    "format_command": "npx prettier --write ."
  },
  "dap_config": {}
}
