{
  "schema_version": 1,
  "sdk": "reactNative",
  "sdk_version": "latest",
  "display_name": "React (Node.js + Vite)",
  "description": "React web development via Node.js LTS and Vite on Termux. Supports ARM64. Includes npm. Create, run and build React apps in the browser via a local dev server.",
  "package": {
    "type": "pkg",
    "arch": "arm64",
    "size_mb": 80
  },
  "package_author": {
    "name": "Termux / Node.js Foundation",
    "github": "https://github.com/termux/termux-packages"
  },
  "json_author": {
    "name": "Yato",
    "date": "2026-04-08"
  },
  "install_steps": [
    {
      "type": "shell",
      "command": "apt-get update -y 2>&1 && apt-get install -y nodejs-lts 2>&1",
      "description": "Installing Node.js LTS"
    }
  ],
  "config_steps": [
    {
      "type": "shell",
      "command": "node --version 2>&1 && npm --version 2>&1",
      "description": "Verifying Node.js and npm versions"
    },
    {
      "type": "shell",
      "command": "npm install -g typescript typescript-language-server 2>&1",
      "description": "Installing TypeScript Language Server (LSP)"
    },
    {
      "type": "shell",
      "command": "npm install -g eslint prettier 2>&1",
      "description": "Installing ESLint and Prettier"
    },
    {
      "type": "shell",
      "command": "typescript-language-server --version 2>&1 && echo 'LSP OK'",
      "description": "Verifying TypeScript LSP binary"
    }
  ],
  "cleanup_steps": [
    {
      "type": "shell",
      "command": "npm uninstall -g typescript typescript-language-server eslint prettier 2>&1 || true",
      "description": "Removing globally installed npm packages on error"
    }
  ],
  "uninstall_steps": [
    {
      "type": "shell",
      "command": "npm uninstall -g typescript typescript-language-server eslint prettier 2>&1 || true",
      "description": "Removing TypeScript LSP and tools"
    },
    {
      "type": "shell",
      "command": "apt-get remove -y nodejs-lts 2>&1 || true",
      "description": "Removing Node.js LTS"
    }
  ],
  "verify_binary": "node",
  "verify_command": "node --version",
  "run_config": {
    "run": "npm run dev -- --host",
    "supports_devices": false,
    "build_debug": "npm run build",
    "build_release": "npm run build"
  },
  "sdk_config": {
    "new_project_cmd": "npm create vite@latest $name -- --template react-ts && cd $name && npm install",
    "default_entry_file": "src/App.tsx",
    "file_extensions": ["js", "jsx", "ts", "tsx", "css", "html", "json"],
    "sync_command": "npm install",
    "sync_trigger_file": "package.json",
    "format_command": "npx prettier --write ."
  },
  "dap_config": {}
}
