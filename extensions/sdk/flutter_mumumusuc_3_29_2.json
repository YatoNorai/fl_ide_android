{
  "schema_version": 1,
  "sdk": "flutter",
  "sdk_version": "3.29.2",
  "display_name": "Flutter SDK 3.29.2 (mumumusuc)",
  "description": "Flutter 3.29.2 compiled for Termux as a .deb package. Supports ARM64 (aarch64). Includes Dart SDK and all Flutter tools.",
  "package": {
    "type": "deb",
    "url": "https://github.com/mumumusuc/termux-flutter/releases/download/3.29.2/flutter_3.29.2_aarch64.deb",
    "filename": "flutter_3.29.2_aarch64.deb",
    "arch": "arm64",
    "size_mb": 200
  },
  "package_author": {
    "name": "mumumusuc",
    "github": "https://github.com/mumumusuc/termux-flutter"
  },
  "json_author": {
    "name": "Yato",
    "date": "2026-03-18"
  },
  "install_steps": [
    {
      "type": "shell",
      "command": "pkg install -y x11-repo 2>&1",
      "description": "Installing x11-repo (pre-dependency)"
    },
    {
      "type": "shell",
      "command": "dpkg -i $DOWNLOAD_PATH 2>&1; apt-get install -f -y 2>&1",
      "description": "Installing Flutter .deb and resolving all dependencies"
    },
    {
      "type": "shell",
      "command": "pkg install -y git 2>&1",
      "description": "Installing git (required by Flutter)"
    },
    {
      "type": "shell",
      "command": "grep -qxF 'export PATH=\"$PATH:$PREFIX/flutter/bin\"' $HOME/.bashrc || echo 'export PATH=\"$PATH:$PREFIX/flutter/bin\"' >> $HOME/.bashrc",
      "description": "Adding Flutter to PATH"
    }
  ],
  "config_steps": [
    {
      "type": "shell",
      "command": "flutter config --no-analytics 2>&1 || true",
      "description": "Disabling analytics"
    },
    {
      "type": "shell",
      "command": "flutter config --android-sdk $ANDROID_HOME 2>&1 || true",
      "description": "Configuring Android SDK path"
    },
    {
      "type": "shell",
      "command": "flutter doctor -v 2>&1 || true",
      "description": "Running Flutter doctor"
    }
  ],
  "cleanup_steps": [
    {
      "type": "shell",
      "command": "dpkg --purge flutter 2>&1 || true",
      "description": "Removing Flutter .deb package on error"
    }
  ],
  "uninstall_steps": [
    {
      "type": "shell",
      "command": "dpkg --purge flutter 2>&1 || true",
      "description": "Uninstalling Flutter"
    },
    {
      "type": "shell",
      "command": "rm -rf \"$PREFIX/opt/flutter\" 2>&1 || true",
      "description": "Removing Flutter directory"
    },
    {
      "type": "shell",
      "command": "sed -i '/flutter\\/bin/d' $HOME/.bashrc 2>&1 || true",
      "description": "Cleaning Flutter from .bashrc"
    }
  ],
  "verify_binary": "flutter",
  "verify_command": "flutter --version",
  "run_config": {
    "run": "flutter run",
    "supports_devices": true,
    "device_param": "-d",
    "build_apk": "flutter build apk",
    "build_appbundle": "flutter build appbundle",
    "build_debug": "flutter build apk --debug"
  },
  "sdk_config": {
    "new_project_cmd": "flutter create $name",
    "default_entry_file": "lib/main.dart",
    "file_extensions": ["dart", "yaml", "json"],
    "sync_command": "flutter pub get",
    "sync_trigger_file": "pubspec.yaml",
    "format_command": "dart format"
  },
  "dap_config": {
    "adapter_binary": "$FLUTTER_ROOT/bin/flutter",
    "adapter_args": ["debug_adapter"],
    "adapter_id": "dart",
    "launch_program": "lib/main.dart",
    "devices_command": "$FLUTTER_ROOT/bin/flutter devices --machine",
    "build_done_strings": [
      "Syncing files to device",
      "flutter run key commands",
      "Running with soundNullSafety",
      "To hot reload"
    ],
    "platform_device_map": {
      "android": "android",
      "web": "web-server",
      "linux": "linux"
    },
    "web_platform": "web",
    "web_server_args": [
      "-d", "web-server",
      "--web-port", "5050",
      "--web-hostname", "localhost",
      "--no-start-paused"
    ]
  }
}
