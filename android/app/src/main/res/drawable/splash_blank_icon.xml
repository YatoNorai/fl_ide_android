<?xml version="1.0" encoding="utf-8"?>
<!-- Empty vector used as the windowSplashScreenAnimatedIcon on Android 12+.
     Setting this suppresses the default app icon from appearing during cold
     start, so only the background color is visible — which matches the
     Flutter Lottie splash and makes the transition seamless. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
</vector>
