<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light-mode window while the Flutter engine starts. Background matches
         MorphingDevicesSplash.backgroundLightColor so there is no flash. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Applied once Flutter draws its first frame. White keeps the window
         consistent with the Lottie splash background. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">#FFFFFF</item>
    </style>
</resources>
