<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31) splash-screen config — dark mode.

    • windowSplashScreenBackground  — matches MorphingDevicesSplash.backgroundDarkColor (#0B0B0B)
    • windowSplashScreenAnimatedIcon — blank vector to suppress the app icon
    • windowSplashScreenIconBackgroundColor — same as main background
-->
<resources>
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">#0B0B0B</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_blank_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#0B0B0B</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">#0B0B0B</item>
    </style>
</resources>
